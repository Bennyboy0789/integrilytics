# Contact form email delivery (SMTP)
# Copy this file to `.env.local` and fill in your mailbox's SMTP settings.
# On Vercel, add these same keys under Project Settings → Environment Variables.

# SMTP server host, e.g. smtp.gmail.com, smtp.office365.com, mail.yourhost.com
SMTP_HOST=

# Port: 587 for STARTTLS (default) or 465 for SSL
SMTP_PORT=587

# Set to "true" only if using port 465 (implicit SSL). Leave blank/false for 587.
SMTP_SECURE=false

# SMTP login (usually the full email address)
SMTP_USER=

# SMTP password or app-specific password
SMTP_PASS=

# Where form submissions are delivered (the inbox you want to receive leads)
CONTACT_TO_EMAIL=info@integrilyticsinc.com

# The "from" address on outgoing mail. Many hosts require this to match SMTP_USER.
# Defaults to SMTP_USER if left blank.
CONTACT_FROM_EMAIL=


# ------------------------------------------------------------------
# Booking page — Microsoft 365 calendar (Microsoft Graph, app-only)
# ------------------------------------------------------------------
# Setup (your Microsoft 365 admin, once):
#   1. Azure Portal -> Microsoft Entra ID -> App registrations -> New registration.
#   2. Copy the Application (client) ID and Directory (tenant) ID.
#   3. Certificates & secrets -> New client secret -> copy the VALUE.
#   4. API permissions -> Add -> Microsoft Graph -> Application permissions ->
#      add Calendars.ReadWrite  (and OnlineMeetings.ReadWrite for Teams links).
#      Then click "Grant admin consent".
#   5. IMPORTANT (least privilege): restrict the app to only the booking mailbox
#      with an Application Access Policy in Exchange Online PowerShell:
#        New-ApplicationAccessPolicy -AppId <client-id> `
#          -PolicyScopeGroupId <booking-mailbox-or-group> `
#          -AccessRight RestrictAccess -Description "IntegriLytics booking app"
#   6. On Vercel, add these same keys under Project Settings -> Environment Variables.

MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# The mailbox (UPN/email) whose calendar receives bookings and provides free/busy.
BOOKING_MAILBOX=info@integrilyticsinc.com

# Optional: Windows time-zone id used for slots/events (default: Eastern Standard Time).
BOOKING_TIMEZONE=Eastern Standard Time

# Optional: shown as the location for Office consultations.
OFFICE_ADDRESS=IntegriLytics Office, Fayetteville, NC
